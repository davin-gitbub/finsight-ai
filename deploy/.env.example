# FinSight AI — 生产环境变量模板
# 复制此文件为 backend/.env 并填入真实值

# --- LLM API (DeepSeek 代理 Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-your-key-here
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# --- 应用配置 ---
APP_NAME=FinSight AI
DEBUG=false

# --- CORS (逗号分隔；同源 Nginx 部署留空即可) ---
CORS_ORIGINS=

# --- ChromaDB (相对路径，Docker 内映射到 /app/chroma_db) ---
CHROMA_PERSIST_DIR=./chroma_db

# --- 用户反馈存储 ---
FEEDBACK_PATH=./feedback/feedback.jsonl

# --- 服务绑定 ---
HOST=0.0.0.0
PORT=8000
